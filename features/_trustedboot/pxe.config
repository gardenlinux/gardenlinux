#!/usr/bin/env bash

set -eufo pipefail

rootfs="$1"
out_dir="$2"
vmlinuz="$3"
initrd="$4"
cmdline="$5"

case "$BUILDER_ARCH" in
amd64)
	uefi_arch=X64
	;;
arm64)
	uefi_arch=AA64
	;;
esac

echo "Building signed UKI for PXE boot (architecture: $BUILDER_ARCH)"

# Build UKI for PXE boot
uki="$(mktemp)"
ukify build \
	--stub "$rootfs/usr/lib/systemd/boot/efi/linux$(tr '[:upper:]' '[:lower:]' <<<"$uefi_arch").efi.stub" \
	--linux "$out_dir/$vmlinuz" \
	--initrd "$out_dir/$initrd" \
	--cmdline "$cmdline" \
	--output "$uki"

# Sign UKI with Secure Boot keys (same pattern as usi.config)
PKCS11_MODULE_PATH="/usr/lib/$(uname -m)-linux-gnu/pkcs11/aws_kms_pkcs11.so"
export PKCS11_MODULE_PATH

cert_base="/builder/cert/secureboot.db"

if [ -f "$cert_base.key" ]; then
	sbs_key_params=(--key "$cert_base.key")
elif [ -f "$cert_base.arn" ]; then
	sbs_key_params=(--engine pkcs11 --key "pkcs11:token=$(basename "$(cat "$cert_base.arn")" | cut -c -32)")
else
	echo "neither $cert_base.key nor $cert_base.arn exists, but at least one is required" >&2
	exit 1
fi

datefudge -s "@$BUILDER_TIMESTAMP" sbsign \
	--cert "$cert_base.crt" \
	"${sbs_key_params[@]}" \
	--output "$out_dir/boot.efi" \
	"$uki"

rm "$uki"

echo "Signed UKI created at $out_dir/boot.efi"
