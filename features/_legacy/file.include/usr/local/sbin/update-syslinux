#!/usr/bin/env bash
# 
# update-syslinux - Generate syslinux configuration for BIOS boot
#
# This script generates syslinux.cfg from either:
# 1. Primary mode: systemd-boot loader entries (when available)
# 2. Fallback mode: directly from /boot kernels (for BIOS systems)
#

set -uoeE pipefail

configDir="/etc/kernel/cmdline.d"
configFile="syslinux/syslinux.cfg"

check_config() {
	local f=$1
	if [ ! -f "$ESP_PATH/$(get_linux "$f" | cut -c 3-)" ]; then
	  echo "ce plm"
		return 1
	fi
	for i in $(get_initrd "$f" | tr ',' ' '); do
	  if [ ! -f "$ESP_PATH/$(echo "$i" | cut -c 3-)" ]; then
		  return 1
	  fi
	done
	return 0
}

err() {
  echo "${@}" >&2
  exit 1
}

get_options() {
	local f=$1
		options=$(awk '/^options/{ $1=""; print $0 }' "$f")
	if [ -z "$options" ]; then
		err "no options detected for $f"
	fi
	echo "$options"
}

get_version() {
	local f=$1
	version=$(awk '/^version/{ print $2 }' "$f")
	if [ -z "$version" ]; then
		err "no version field detected for $f"
	fi
	echo "$version"
}

get_linux() {
	local f=$1
	linux=$(awk '/^linux/{ print ".."$2 }' "$f")
	if [ -z "$linux" ]; then
		err "no kernel field detected for $f"
	fi
	echo "$linux"
}

get_initrd() {
	local f=$1
	initrd=$(awk '/^initrd/{ print ".."$2 }' "$f" | paste -s -d ',')
	if [ -z "$initrd" ]; then
		err "no initrd field detected for $f"
	fi
	echo "$initrd"
}

generate_fallback_config() {
	# Read options from /etc/kernel/cmdline if available
	if [ -f /etc/kernel/cmdline ]; then
		options=$(cat /etc/kernel/cmdline)
	else
		options="root=${DEVICE} ${CMDLINE_LINUX}"
	fi
	
	mkdir -p "${ESP_PATH}/syslinux"
	
	# Collect and sort kernels
	local kernels=()
	for kernel in /boot/vmlinuz-*; do
		[ -e "$kernel" ] || continue
		kernels+=("$kernel")
	done
	
	if [ ${#kernels[@]} -eq 0 ]; then
		err "No kernels found in /boot"
	fi
	
	# Sort by version (newest first)
	readarray -t sorted_kernels < <(printf '%s\n' "${kernels[@]}" | sort -rV)
	
	{
		echo "# automatically generated by update-syslinux (fallback mode)"
		echo "UI menu.c32"
		echo "PROMPT 0"
		echo
		echo "MENU TITLE Gardenlinux"
		echo "TIMEOUT ${TIMEOUT:-1}"
		
		local first=1
		for kernel in "${sorted_kernels[@]}"; do
			local version="${kernel#/boot/vmlinuz-}"
			local initrd="/boot/initrd.img-${version}"
			
			if [ ! -f "$initrd" ]; then
				echo "Warning: no initrd found for $kernel, skipping" >&2
				continue
			fi
			
			# Copy kernel/initrd to ESP
			cp "$kernel" "${ESP_PATH}/vmlinuz-${version}"
			cp "$initrd" "${ESP_PATH}/initrd.img-${version}"
			
			if [ "$first" == "1" ]; then
				echo "DEFAULT Linux-${version}"
				echo
				first=0
			fi
			
			echo "LABEL Linux-${version}"
			echo " LINUX /vmlinuz-${version}"
			echo " APPEND ${options}"
			echo " INITRD /initrd.img-${version}"
			echo
		done
	} > "${ESP_PATH}/syslinux/syslinux.cfg.new"
	
	mv "${ESP_PATH}/syslinux/syslinux.cfg.new" "${ESP_PATH}/syslinux/syslinux.cfg"
	echo "Generated ${ESP_PATH}/syslinux/syslinux.cfg"
}

if ! which syslinux &> /dev/null; then
	exit 0
fi

# Auto-detect ESP path if not set
if [ -z "${ESP_PATH:-}" ]; then
	# Try bootctl first (works on EFI systems)
	if ESP_PATH=$(bootctl -p 2>/dev/null); then
		: # Success
	elif [ -d /efi ] && mountpoint -q /efi; then
		ESP_PATH=/efi
	elif [ -d /boot/efi ] && mountpoint -q /boot/efi; then
		ESP_PATH=/boot/efi
	else
		err "Cannot detect ESP. Mount ESP at /efi or /boot/efi, or set ESP_PATH"
	fi
fi

for i in "${configDir}"/*-*.cfg; do
	[ -e "$i" ] || continue
	# shellcheck disable=SC1090
	source "$i"
done

configs=()

# Check for loader entries
shopt -s nullglob
loader_entries=("${ESP_PATH}"/loader/entries/*.conf*)
shopt -u nullglob

if [ ${#loader_entries[@]} -gt 0 ]; then
	# Primary mode: parse loader entries (existing behavior)
	for config in "${loader_entries[@]}"; do
		if check_config "$config"; then
			configs+=("${config}")
		else
			err "kernel or initrd doesn't exist for $config"
		fi
	done
	
	if [ "${#configs[@]}" == "0" ]; then
		err "no valid configs found under $ESP_PATH/loader/entries"
	fi
else
	# Fallback mode: generate config directly from /boot kernels
	echo "No loader entries found, generating syslinux config from /boot kernels"
	generate_fallback_config
	exit 0
fi

readarray -t vSorted < <(printf '%s\n' "${configs[@]}" | sort -rV)
{
  echo "# automatically generated by update-syslinux"
	echo "UI menu.c32"
	echo "PROMPT 0"
	echo
	echo "MENU TITLE Gardenlinux"
	echo "TIMEOUT $TIMEOUT"
	echo "DEFAULT Linux-$(get_version "${vSorted[0]}")"
	echo
	for v in "${vSorted[@]}"; do
		echo "LABEL Linux-$(get_version "$v")"
		echo " LINUX $(get_linux "$v")"
		echo " APPEND $(get_options "$v")"
		echo " INITRD $(get_initrd "$v")"
		echo
	done
} > "${ESP_PATH}/${configFile}.new"

mv "${ESP_PATH}/${configFile}.new" "${ESP_PATH}/${configFile}"
