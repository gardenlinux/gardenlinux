id: gardenlinux-test
unit: test plan
_name: Garden Linux HW Test (Latest)
_description: Hardware validation tests for Garden Linux ccloud delivery to HW vendors
include:
nested_part:
    dmesg_output
    dmesg_output_attachment
    hw_encrypt_enabled_check
    hw_encrypt_enabled_check_output
    virtualization_disabled_output
    virtualization_disabled_output_attachment
    tpm_enabled_check
    tpm_enabled_check_attachment
    storage_check
    network_check
    cpu_check
    memory_check
    usb_check
    ipmi_check
    ipmi_check_attachment
    bios_info_check
    bios_info_check_attachment
    stress_check

id: dmesg_output
unit: test plan
_name: dmesg output
_description: dmesg output sorted by severity
include:
    ccloud/dmesg_output                 certification-status=non-blocker

id: dmesg_output_attachment
unit: test plan
_name: dmesg attachment
_description: attachment for dmesg
include:
    ccloud/dmesg_output_attachment      certification-status=non-blocker

id: hw_encrypt_enabled_check
unit: test plan
_name: hw_encrypt_enabled_check
_description: encrypt enabled check
include:
    ccloud/hw_encrypt_enabled_check     certification-status=non-blocker

id: hw_encrypt_enabled_check_output
unit: test plan
_name: hw_encrypt_enabled_check_output
_description: encrypt enabled check attachment
include:
    ccloud/hw_encrypt_enabled_check_output  certification-status=non-blocker

id: virtualization_disabled_output
unit: test plan
_name: virtualization_disabled_output
_description: check for virtualization disabled
include:
    ccloud/virtualization_disabled_output   certification-status=non-blocker

id: virtualization_disabled_output_attachment
unit: test plan
_name: virtualization_disabled_output_attachment
_description: attachment for virtualization disabled check
include:
    ccloud/virtualization_disabled_output_attachment    certification-status=non-blocker

id: tpm_enabled_check
unit: test plan
_name: tpm_enabled_check
_description: check for tpm
include:
    ccloud/tpm_enabled_check            certification-status=non-blocker

id: tpm_enabled_check_attachment
unit: test plan
_name: tpm_enabled_check_attachment
_description: attachment for tpm check
include:
    ccloud/tpm_enabled_check_attachment certification-status=non-blocker

id: storage_check
unit: test plan
_name: storage_check
_description: storage device detection, SMART health and read throughput
include:
    com.canonical.certification::disk/detect        certification-status=non-blocker
    com.canonical.certification::disk/smart_{name} certification-status=non-blocker
    com.canonical.certification::disk/read_performance_{name}   certification-status=non-blocker

id: network_check
unit: test plan
_name: network_check
_description: network interface detection, link state and basic connectivity
include:
    com.canonical.certification::networking/info_device{__index__}_{interface}  certification-status=non-blocker
    com.canonical.certification::networking/gateway_ping    certification-status=non-blocker

id: cpu_check
unit: test plan
_name: cpu_check
_description: CPU topology, frequency and flags
include:
    com.canonical.certification::cpu/topology               certification-status=non-blocker
    com.canonical.certification::cpu/cpufreq_test-server    certification-status=non-blocker

id: memory_check
unit: test plan
_name: memory_check
_description: memory information and basic check
include:
    com.canonical.certification::memory/info    certification-status=non-blocker

id: usb_check
unit: test plan
_name: usb_check
_description: USB controller detection and device enumeration
include:
    com.canonical.certification::usb/detect         certification-status=non-blocker
    com.canonical.certification::usb/storage-detect certification-status=non-blocker

id: ipmi_check
unit: test plan
_name: ipmi_check
_description: check IPMI/BMC interface detection and sensor availability
include:
    ccloud/ipmi_check                   certification-status=non-blocker

id: ipmi_check_attachment
unit: test plan
_name: ipmi_check_attachment
_description: attachment for IPMI check
include:
    ccloud/ipmi_check_attachment        certification-status=non-blocker

id: bios_info_check
unit: test plan
_name: bios_info_check
_description: check firmware version, BIOS date and DMI/SMBIOS info
include:
    ccloud/bios_info_check              certification-status=non-blocker

id: bios_info_check_attachment
unit: test plan
_name: bios_info_check_attachment
_description: attachment for BIOS/firmware info check
include:
    ccloud/bios_info_check_attachment   certification-status=non-blocker

id: stress_check
unit: test plan
_name: stress_check
_description: CPU and memory longevity stress tests
include:
    com.canonical.certification::stress/cpu_stress_ng_test  certification-status=non-blocker
