#!/usr/bin/env bash

set -eufo pipefail

input="$1"
output="$2"

export PATH="/builder/image.d:$PATH"

rootfs="$(mktemp -d)"
mount -t tmpfs -o size="${TEMPFS_SIZE:-4G}" tmpfs "$rootfs"
tar --extract --xattrs --xattrs-include '*' --directory "$rootfs" < "$input"

# Detect kernel version (robust method from image.esp.tar)
kernel="$(find "$rootfs/boot/" -name 'vmlinuz-*' -printf '%P\n' | sort -V | tail -n 1)"

# Detect if this is a USI build (no traditional initrd in /boot)
is_usi=0
if ! ls "$rootfs/boot/"initrd* >/dev/null 2>&1; then
	is_usi=1
	echo "Detected USI build (no traditional initrd in /boot)"
fi

# Create output directory for artifacts
out_dir="$(mktemp -d)"

# Always copy kernel
cp "$rootfs/boot/$kernel" "$out_dir/vmlinuz"

if [ "$is_usi" -eq 0 ]; then
	# Traditional PXE: copy existing initrd
	cp "$rootfs/boot/"initrd* "$out_dir/initrd"
else
	# USI PXE: Generate initrd with dracut for network boot
	echo "Generating network boot initrd with dracut for kernel ${kernel#vmlinuz-}"
	
	# Mount necessary filesystems for chroot (same pattern as image.esp.tar)
	mount --rbind /proc "$rootfs/proc"
	
	# Minimal /dev setup (proven approach from image.esp.tar)
	mount -t tmpfs -o mode=0755,size=4k tmpfs "$rootfs/dev"
	for i in null zero random urandom; do
		touch "$rootfs/dev/$i"
		mount --bind "/dev/$i" "$rootfs/dev/$i"
	done
	cp --no-dereference /dev/{fd,stdin,stdout,stderr} "$rootfs/dev/"
	
	mount -t tmpfs -o size=1G tmpfs "$rootfs/tmp"
	
	# Copy initrd.include from features (same pattern as image.esp.tar)
	mkdir "$rootfs/tmp/initrd.include"
	IFS=',' read -r -a features <<< "$BUILDER_FEATURES"
	for feature in "${features[@]}"; do
		if [ -e "/builder/features/$feature/initrd.include" ]; then
			cp -a "/builder/features/$feature/initrd.include/." "$rootfs/tmp/initrd.include"
		fi
	done
	
	# The gardenlinux-live module (from _pxe feature) handles:
	# - HTTP fetch of squashfs via curl
	# - OverlayFS setup for live boot
	# - Network via systemd-networkd
	# - Ignition support
	chroot "$rootfs" dracut \
		--no-hostonly \
		--force \
		--tmpdir /tmp \
		--kver "${kernel#vmlinuz-}" \
		--modules "bash systemd systemd-initrd kernel-modules kernel-modules-extra terminfo dracut-systemd base fs-lib gardenlinux-live" \
		--reproducible \
		--include '/tmp/initrd.include' / \
		/tmp/initrd
	
	cp "$rootfs/tmp/initrd" "$out_dir/initrd"
	
	# Unmount in reverse order (same pattern as image.esp.tar)
	umount -l "$rootfs/proc"
	umount -R "$rootfs/dev"
	umount "$rootfs/tmp"
fi

# Read cmdline
read -r _ cmdline < "$rootfs/etc/kernel/cmdline"
echo "$cmdline" > "$out_dir/cmdline"

# Create squashfs
echo "Creating root.squashfs"
mksquashfs "$rootfs" "$out_dir/root.squashfs" -noappend -comp xz -mkfs-time "$BUILDER_TIMESTAMP" -all-time "$BUILDER_TIMESTAMP"

# Append squashfs checksum to initrd
sha256sum "$out_dir/root.squashfs" | head -c 64 > "$out_dir/root.squashfs.sha256sum"
echo root.squashfs.sha256sum | cpio -H newc -o -D "$out_dir" | xz --check=crc32 >> "$out_dir/initrd"

# For USI builds, create UKI for PXE boot via pxe.config hooks
if [ "$is_usi" -eq 1 ]; then
	echo "Calling pxe.config hooks for UKI generation"
	IFS=',' read -r -a features <<< "$BUILDER_FEATURES"
	for feature in "${features[@]}"; do
		if [ -e "/builder/features/$feature/pxe.config" ]; then
			echo "Executing /builder/features/$feature/pxe.config"
			"/builder/features/$feature/pxe.config" "$rootfs" "$out_dir" vmlinuz initrd "$cmdline"
		fi
	done
fi

umount "$rootfs"
rmdir "$rootfs"

# Create archive with all available files
archive_files=(vmlinuz initrd cmdline root.squashfs)
if [ -f "$out_dir/boot.efi" ]; then
	archive_files+=(boot.efi)
	echo "Including boot.efi (UKI) in archive"
fi

tar --create --mtime="@$BUILDER_TIMESTAMP" --sort name --numeric-owner \
	--pax-option=exthdr.name=%d/PaxHeaders/%f,delete=atime,delete=ctime \
	-C "$out_dir" "${archive_files[@]}" | gzip > "$output"

rm -rf "$out_dir"

sha256sum "$output"
