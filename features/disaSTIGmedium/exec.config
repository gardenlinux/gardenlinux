#!/usr/bin/env bash
set -Eeuo pipefail

# =============================================================================
# Audit (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-service-auditd-enable
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000122-GPOS-00063/
systemctl enable auditd.service

# GL-TESTCOV-disaSTIGmedium-config-audit-log-permissions
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000057-GPOS-00027/
chmod 0600 /var/log/audit

# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000057-GPOS-00027/
chown root:root -R /var/log/audit

# GL-TESTCOV-disaSTIGmedium-config-audit-auditd-conf
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000057-GPOS-00027/
sed -i '/^log_group/D' /etc/audit/auditd.conf
sed -i /^log_file/a'log_group = root' /etc/audit/auditd.conf

# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000051-GPOS-00024/
sed -i '/^max_log_file\b/D' /etc/audit/auditd.conf
echo 'max_log_file = 8' >> /etc/audit/auditd.conf
sed -i '/^num_logs\b/D' /etc/audit/auditd.conf
echo 'num_logs = 5' >> /etc/audit/auditd.conf
sed -i '/^space_left_action\b/D' /etc/audit/auditd.conf
echo 'space_left_action = email' >> /etc/audit/auditd.conf

# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000059-GPOS-00029/
chmod -R g-w,o-rwx /var/log/audit
# ensure rotated audit logs are readable by root (not 0400)
find /var/log/audit -type f -exec chmod 0600 '{}' \;

# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000063-GPOS-00032/
chmod -R 0640 /etc/audit/audit*.{rules,conf} /etc/audit/rules.d/*

# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000063-GPOS-00032/
chown root:root /etc/audit/audit*.{rules,conf} /etc/audit/rules.d/*

# =============================================================================
# SSH Hardening (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-config-ssh-sshd-config-clientalivecountmax
# V-238218: base sshd_config sets ClientAliveCountMax 0 before the Include directive,
# so the drop-in cannot override it — patch the base file directly
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000126-GPOS-00066/
sed -i 's/^ClientAliveCountMax.*/ClientAliveCountMax 1/' /etc/ssh/sshd_config

# =============================================================================
# OS Hardening (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-config-sudoers-wheel
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000373-GPOS-00156/
# Truncate rather than delete — ssh/exec.config chmods this file and would fail if absent
echo -n > /etc/sudoers.d/wheel

# GL-TESTCOV-disaSTIGmedium-config-login-defs-umask
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000480-GPOS-00228/
sed -i 's/^\(UMASK\s*\).*/\1077/' /etc/login.defs

# GL-TESTCOV-disaSTIGmedium-config-var-log-file-permissions
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000205-GPOS-00083/
find /var/log -perm /137 ! -name '*[bw]tmp' ! -name '*lastlog' -type f -exec chmod 640 '{}' \;

# GL-TESTCOV-disaSTIGmedium-config-root-locked
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000109-GPOS-00056/
passwd --lock root

# GL-TESTCOV-disaSTIGmedium-config-login-defs-encrypt
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000120-GPOS-00061/
sed -i 's/^ENCRYPT_METHOD.*/ENCRYPT_METHOD SHA512/' /etc/login.defs

# =============================================================================
# Journal permissions (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-config-journal-permissions
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000206-GPOS-00084/
mkdir -p /var/log/journal
chown root:systemd-journal /var/log/journal
chmod 2750 /var/log/journal

# =============================================================================
# Getty autologin (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-config-getty-no-autologin
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000480-GPOS-00229/
mkdir -p /etc/systemd/system/getty@.service.d
cat > /etc/systemd/system/getty@.service.d/no-autologin.conf << 'UNIT'
[Service]
ExecStart=
ExecStart=-/sbin/agetty -o '-p -- \\u' --noclear - $TERM
UNIT

# =============================================================================
# PAM faildelay (CAT II)
# =============================================================================

# GL-TESTCOV-disaSTIGmedium-config-pam-common-auth-faildelay
# https://stigaview.com/products/srg-gpos/v3r2/SRG-OS-000480-GPOS-00226/
if ! grep -q 'pam_faildelay' /etc/pam.d/common-auth 2>/dev/null; then
    sed -i '1s/^/auth required pam_faildelay.so delay=4000000\n/' /etc/pam.d/common-auth
fi
