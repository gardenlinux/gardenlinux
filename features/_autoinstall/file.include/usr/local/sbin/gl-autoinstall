#!/usr/bin/env bash
set -e

# Check kernel command line for target override (gl.install.target=/dev/sdX)
get_cmdline_target() {
    local target
    target=$(cat /proc/cmdline | tr ' ' '\n' | grep '^gl.install.target=' | cut -d= -f2-)
    if [ -n "$target" ] && [ -b "$target" ]; then
        echo "$target"
        return 0
    fi
    return 1
}

# Find the first suitable block device for installation
# Skip: loop devices, CD-ROM (sr*), read-only devices, the live ISO device
find_target_disk() {
    for dev in /sys/block/*; do
        name=$(basename "$dev")
        
        # Skip loop devices, CD-ROMs, and ram disks
        case "$name" in
            loop*|sr*|ram*|zram*) continue ;;
        esac
        
        # Skip read-only devices
        if [ "$(cat "$dev/ro" 2>/dev/null)" = "1" ]; then
            continue
        fi
        
        # Skip removable devices (USB, CD, etc)
        if [ "$(cat "$dev/removable" 2>/dev/null)" = "1" ]; then
            continue
        fi
        
        echo "/dev/$name"
        return 0
    done
    return 1
}

# Try kernel command line first, then auto-detect
target=$(get_cmdline_target || find_target_disk || true)
if [ -z "$target" ]; then
    echo "ERROR: No suitable block device found for installation"
    echo "Hint: Pass gl.install.target=/dev/sdX on kernel command line"
    exit 1
fi

echo "Auto-installing Garden Linux to $target..."
export GL_INSTALL_TARGET="$target"
/opt/install/install.sh

# echo "Installation complete. Powering off..."
# sync
# systemctl poweroff

echo "Installation completed successfully!"
echo "Booting into installed system via kexec..."

# Find the installed kernel version from the target system
kernel=$(ls /opt/install/boot/vmlinuz-* 2>/dev/null | head -1 | sed 's/.*vmlinuz-//')
if [ -z "$kernel" ]; then
    echo "ERROR: Could not find installed kernel in /opt/install/boot/"
    exit 1
fi

echo "Found kernel version: $kernel"
kexec -l /opt/install/boot/vmlinuz-${kernel} --initrd=/opt/install/boot/initrd.img-${kernel} --command-line="root=LABEL=ROOT ro console=ttyS0 console=tty0"
kexec -e
